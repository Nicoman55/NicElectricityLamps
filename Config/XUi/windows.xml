<configs>
	<append xpath="/windows">
		<window name="windowElectricityLampsStats" width="228" height="540" panel="Left" controller="ElectricityLamps.XUiC_ElectricityLampsStats, ElectricityLamps" >
			<panel name="header" height="43" depth="1" backgroundspritename="ui_game_panel_header">
				<sprite depth="2" name="windowIcon" style="icon32px" pos="5,-5" sprite="ui_game_symbol_resource"/>
				<label style="header.name" text="OPTIONS" text_key="xuiLightOptions" />
			</panel>
			<rect name="content" depth="0" pos="0,-46" height="525">
				<sprite depth="4" name="backgroundMain" sprite="menu_empty3px" color="[black]" type="sliced" fillcenter="false" />
				<sprite depth="1" color="[darkGrey]" type="sliced" width="228" height="525" pos="0,0" />
				<rect depth="2" pos="6,-5">
					<grid name="stats" rows="9" cols="1" pos="3,-5" cell_width="222" cell_height="40" repeat_content="false" >
					    <panel height="30" width="340" disableautobackground="true">
						    <label text_key="xuiLightPropState" width ="180" font_size="22" pos ="2,-2" />
						    <combobox name="cbxLightState" width ="130" height="30" type="ComboBoxEnum`1[LightStateType]" localization_prefix="xuiLightPropState" pos="80,-2" />
                        </panel>
						<panel name="panelRate" height="30" width="340" disableautobackground="true">
							<label name="labelRate" text_key="xuiLightPropRate" width="180" height="30" font_size="22" depth="1" pos="2,-2" />
							<combobox name="cbxRate" type="ComboBoxFloat" width="130" height="30" pos="80,-2" value_increment=".1" value_min="0" value_max="20" value_wrap="false" format_string="0.0" />
						</panel>
						<panel name="panelDelay" height="30" width="340" disableautobackground="true">
							<label name="labelDelay" text_key="xuiLightPropDelay" width="180" height="30" font_size="22" depth="1" pos="2,-2" />
							<combobox name="cbxDelay" type="ComboBoxFloat" width="130" height="30" pos="80,-2" value_increment=".1" value_min="0" value_max="10" value_wrap="false" format_string="0.0" />
						</panel>
						<panel height="30" width="340" disableautobackground="true" visible="{showfuel}">
							<label depth="1" width="180" pos="2,-2" name="lblIntensity" font_size="22" text="Intensity" text_key="xuiIntensity" />
							<combobox name ="uiIntensity" type="ComboBoxFloat" width="130" height="30" pos="80,-2" value_increment="{LightIntensityStep}" value_min="{MinLightIntensity}" value_max="{MaxLightIntensity}" value_wrap="false" format_string="0.00" />
						</panel>
						<panel height="30" width="340" disableautobackground="true">
							<label depth="1" width="180" pos="2,-2" name="lblRange" font_size="22" text="Intensity" text_key="xuiRange" />
							<combobox name ="uiRange" type="ComboBoxFloat" width="130" height="30" pos="80,-2" value_increment="{LightRangeStep}" value_min="{MinLightRange}" value_max="{MaxLightRange}" value_wrap="false" format_string="0.00" />
						</panel>
						<panel name="panelBeamAngle" height="30" width="340" disableautobackground="true">
							<label depth="1" width="180" pos="2,-2" name="lblBeamAngle" font_size="22" text="Beam ∠" text_key="xuiAngle" />
							<combobox name ="uiBeamAngle" type="ComboBoxFloat" width="130" height="30" pos="80,-2" value_increment="{BeamAngleStep}" value_min="{MinBeamAngle}" value_max="{MaxBeamAngle}" value_wrap="false" format_string="0°" />
						</panel>
						<panel height="30" width="340" disableautobackground="true" visible="{IsModeNotLocked}">
							<label depth="1" width="180" pos="2,-2" name="lblLightMode" font_size="22" text="Mode" text_key="xuiLightMode" />
							<combobox name="uiUseKelvin" type="ComboBoxBool" localization_prefix="xuiLightMode" width="130" height="30" pos="80,-2" />
						</panel>
						<panel name="panelTemperature" height="30" width="340" disableautobackground="true">
							<label depth="1" width="180" pos="2,-2" name="lblTemperature" font_size="22" text="Temp." text_key="xuiTemperature" />
							<combobox name ="uiTemperature" type="ComboBoxInt" width="130" height="30" pos="80,-2" value_increment="100" value_min="1000" value_max="12000" value_wrap="false" format_string="0K" />
						</panel>
						<panel height="170" width="340" disableautobackground="true" visible="{IsColorScale}">
							<rect name="uiColorPicker" pos="0,-2" controller="ColorPicker">
								<sprite depth="2" name="selectedColor" pos="172,0" style="icon30px" type="sliced"/>
								<texture depth="2" name="svPicker" pos="6,0" width="160" height="160" on_drag="true" on_press="true">
									<sprite depth="2" name="selectedColorSVPointer" pos="0,0" style="icon30px" width="21" height="21" type="sliced" pivot="center" sprite="ui_game_symbol_map_cursor"/>
								</texture>
								<texture depth="2" name="hPicker" pos="172,-33" width="30" height="127" on_drag="true" on_press="true" />
							</rect>
						</panel>
					</grid>
				</rect>
				<label name="lblPowerWarning" text_key="ElectricityLampsPowerWarning" font_size="24" color="[red]" width="228" height="30" pos="0,-462" justify="Center" visible="false" depth="3"/>
				<rect name="btnCopySettings"  depth="3" pos="4,-497"  width="100" height="20" on_press="true">
					<sprite depth="3" sprite="menu_empty3px" color="[darkestGrey]" type="sliced" width="100" height="19" pos="0,0" />
					<label text_key="xuiCopySettings"  font_size="18" width="100" height="20" justify="Center" depth="4" />
				</rect>
				<rect name="btnPasteSettings" depth="3" pos="108,-497" width="100" height="20" on_press="true">
					<sprite depth="3" sprite="menu_empty3px" color="[darkestGrey]" type="sliced" width="100" height="19" pos="0,0" />
					<label text_key="xuiPasteSettings" font_size="18" width="100" height="30" justify="Center" depth="4" />
				</rect>
				<rect name="btnClearClipboard" depth="3" pos="213,-505" width="10" height="10" on_press="true">
					<sprite depth="3" sprite="menu_empty3px" color="[red]" type="sliced" width="10" height="10" pos="0,0" />
					<sprite depth="4" sprite="ui_game_symbol_x" color="255,255,255,255" width="8" height="8" pos="1,-1" style="icon22px" />
				</rect>
			</rect>
		</window>
	</append>
</configs>
